# Variabili ambiente per l'ambiente Docker locale.
# Copia questo file in .env e compila con i tuoi valori.
# NON committare il file .env nel repository (è già in .gitignore).

# ─── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=tecnora_root_secret_change_me
MYSQL_DATABASE=tecnora_wp
MYSQL_USER=tecnora
MYSQL_PASSWORD=tecnora_secret_change_me

# ─── WordPress ────────────────────────────────────────────────────────────────
WP_HOME=http://localhost:8080
WP_SITEURL=http://localhost:8080

# ─── Debug ───────────────────────────────────────────────────────────────────
WP_DEBUG=1
WP_DEBUG_LOG=1
WP_DEBUG_DISPLAY=0
